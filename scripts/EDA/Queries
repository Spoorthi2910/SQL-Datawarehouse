--Retrive first and last order date 

select min(order_date) as minn,max(order_date) as maxx ,
datediff(month,min(order_date),max(order_date))
from gold.fact_sales;
-- Find youngest and oldest customers based on birthdate

select min(birthdate),max(birthdate) ,
DATEDIFF(year,min(birthdate),CURRENT_DATE) as maxage,
datediff(year,max(birthdate),current_date) as minage
from gold.dim_customers
--Total customers per Country

select country,count(*)  as total_customers_by_country
from gold.dim_customers
group by country
order by 2 desc;
--Find total products by category

select category,count(*)
from gold.dim_products
group by category
order by 2 desc;
--Find total customers per gender 

select gender,count(*)
from gold.dim_customers
group by gender
order by 2 desc
-- What is the avg and total revenue generated by category 

select category,avg(cost) as average_revenue,sum(sales_amount) as total_revenue
from gold.dim_products
left join gold.fact_sales on gold.dim_products.product_key = gold.fact_sales.product_key 
group by category 
order by 3 desc;
--Find total revenue generated by each customer

select g.customer_key,first_name,sum(sales_amount) as total_sales
from gold.dim_customers g
join gold.fact_sales f on g.customer_key = f.customer_key
group by g.customer_key,first_name
order by 3 desc
-- What is the sold items distribution per each country 

 select country,sum(quantity) as total_items_sold
 from gold.dim_customers g
 join gold.fact_sales f on g.customer_key = f.customer_key
 group by country
 order by 2 desc

-- Which 5 products generate the Highest Revenue


 select top 5 product_name,sum(sales_amount) as total_revenue 
 from gold.dim_products p
 left join gold.fact_sales f on p.product_key = f.product_key
 group by product_name
 order by 2 desc

 --Find top 10 customers who have generated the highest revenue


select top 10 g.customer_key,first_name,last_name,sum(sales_amount) as total_sales
from gold.dim_customers g
join gold.fact_sales f on g.customer_key = f.customer_key
group by g.customer_key,first_name,last_name
order by 3 desc
